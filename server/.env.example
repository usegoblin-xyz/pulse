# Pulse brain — copy to .env and fill in. Never commit the real .env.

# --- Anam avatar (the talking Pulse) ---
# Use the SAME Anam API key Kara/Goblin Labs uses — the Pulse avatar lives in
# that account.
ANAM_API_KEY=

# Pulse's avatar + voice + persona. Defaults are baked in (avatar a3f92a18…,
# voice Laurent, Anam's built-in LLM, the system prompt in src/pulse-prompt.ts).
# Override any of them here:
# PULSE_AVATAR_ID=a2f0f964-6d5d-4bd9-81fe-973ef6a6215b   # the "Pulse" avatar
# PULSE_VOICE_ID=8e67ed57-4fc0-11f1-84b0-52bacf74fa75   # Laurent — Dependable Anchor
# PULSE_LLM_ID=a7cf662c-2ace-4de1-a21e-ef0fbf144bb7     # Anam built-in LLM
# PULSE_AVATAR_MODEL=cara-3
# PULSE_SYSTEM_PROMPT=                                   # overrides src/pulse-prompt.ts
# PULSE_PERSONA_ID=                                      # if set, mint by reference instead

# --- Form-fill model (the free GLM tier by default) ---
PULSE_MODEL_API_KEY=
# PULSE_MODEL=glm-4.6-flash
# PULSE_MODEL_BASE_URL=https://api.z.ai/api/paas/v4

# --- Hosting ---
# PORT=8787
# PULSE_WEB_ORIGINS=https://usegoblin-xyz.github.io   # if the page is hosted apart from the brain
